    "alert.close.jack_running.message": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Was möchtest du tun?\n\n• Fenster schließen lässt Jack aktiv und JackMate in der Menüleiste erreichbar.\n• JackMate beenden schließt die Anwendung, lässt Jack aber im Hintergrund laufen.\n• Beenden und Jack stoppen stoppt den Jack-Server und schließt JackMate."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "What would you like to do?\n\n• Close window leaves Jack active and JackMate accessible from the menu bar.\n• Quit JackMate closes the application but leaves Jack running in the background.\n• Quit and stop Jack stops the Jack server and closes JackMate."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Que souhaitez-vous faire ?\n\n• Fermer la fenêtre laisse Jack actif et JackMate accessible depuis la barre de menus.\n• Quitter JackMate ferme l'application mais laisse Jack tourner en arrière-plan.\n• Quitter et éteindre Jack arrête le serveur Jack et ferme JackMate."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Cosa vuoi fare?\n\n• Chiudi la finestra lascia Jack attivo e JackMate accessibile dalla barra dei menu.\n• Esci da JackMate chiude l'applicazione ma lascia Jack in esecuzione in background.\n• Esci e spegni Jack ferma il server Jack e chiude JackMate."
          }
        }
      }
    },
