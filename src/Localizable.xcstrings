    "alert.aggregate.button.open": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Audio-MIDI-Setup öffnen"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Open Audio MIDI Setup"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ouvrir Audio MIDI Setup"
          }
        }
      }
    },
    "alert.aggregate.message": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dieses Gerät ist ein macOS-Aggregat.\n\nWenn deine Quellen unabhängige Taktquellen haben (z. B. zwei separate USB-Interfaces), empfiehlt es sich, die Taktquelle in Audio-MIDI-Setup zu konfigurieren — wähle das Aggregatgerät aus und wähle dann eine Master-Taktquelle im entsprechenden Tab.\n\nDiese Hardware-Konfiguration ist robuster als Jacks Software-Korrektur."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This device is a macOS aggregate.\n\nIf your sources have independent clocks (e.g. two separate USB interfaces), consider configuring clock synchronisation in Audio MIDI Setup — select the aggregate device, then choose a master clock source in the dedicated tab.\n\nThis hardware configuration is more robust than Jack's software correction."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ce device est un agrégat macOS.\n\nSi vos sources ont des horloges indépendantes (ex. deux interfaces USB distinctes), pensez à configurer la synchronisation d'horloge dans Audio MIDI Setup — sélectionnez le device agrégé, puis choisissez une source d'horloge maître dans l'onglet dédié.\n\nCette configuration hardware est plus robuste que la correction logicielle de Jack."
          }
        }
      }
    },
    "alert.aggregate.suppress": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Nicht mehr anzeigen"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Don't show this again"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ne plus afficher"
          }
        }
      }
    },
    "alert.aggregate.title": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "macOS-Aggregatgerät"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "macOS Aggregate Device"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Device agrégé macOS"
          }
        }
      }
    },
    "alert.clock_drift.button.open": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Audio-MIDI-Setup öffnen"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Open Audio MIDI Setup"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ouvrir Audio MIDI Setup"
          }
        }
      }
    },
    "alert.clock_drift.message": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Diese Option aktiviert Jacks Taktdriftkorrektur.\n\nSie ist nützlich, wenn deine Ein- und Ausgabegeräte unabhängige Referenztaktquellen haben (z. B. USB-Mikrofon + FireWire-Audiointerface).\n\nEine robustere Alternative: Erstelle ein Aggregatgerät in Audio-MIDI-Setup und konfiguriere dort die Hardware-Taktsynchronisierung. Das Ergebnis ist stabiler und transparenter für alle Anwendungen, nicht nur Jack."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This option enables Jack's clock drift correction.\n\nIt is useful if your input and output devices have independent reference clocks (e.g. USB microphone + FireWire audio interface).\n\nA more robust alternative: create an aggregate device in Audio MIDI Setup and configure hardware clock synchronisation there. The result is more stable and transparent for all applications, not just Jack."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cette option active la correction de dérive d'horloge côté Jack.\n\nElle est utile si vos devices input et output ont des horloges de référence indépendantes (ex. micro USB + interface audio FireWire).\n\nUne alternative plus robuste : créer un device agrégé dans Audio MIDI Setup et y configurer la synchronisation d'horloge hardware. Le résultat est plus stable et transparent pour toutes les applications, pas seulement Jack."
          }
        }
      }
    },
    "alert.clock_drift.suppress": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Nicht mehr anzeigen"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Don't show this again"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ne plus afficher"
          }
        }
      }
    },
    "alert.clock_drift.title": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Clock drift correction"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Clock drift correction"
          }
        },
        "fr": {
          "stringUnit": {
