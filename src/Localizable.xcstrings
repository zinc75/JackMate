    "alert.aggregate.message": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dieses Gerät ist ein macOS-Aggregat.\n\nWenn deine Quellen unabhängige Taktquellen haben (z. B. zwei separate USB-Interfaces), empfiehlt es sich, die Taktquelle in Audio-MIDI-Setup zu konfigurieren — wähle das Aggregatgerät aus und wähle dann eine Master-Taktquelle im entsprechenden Tab.\n\nDiese Hardware-Konfiguration ist robuster als Jacks Software-Korrektur."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This device is a macOS aggregate.\n\nIf your sources have independent clocks (e.g. two separate USB interfaces), consider configuring clock synchronisation in Audio MIDI Setup — select the aggregate device, then choose a master clock source in the dedicated tab.\n\nThis hardware configuration is more robust than Jack's software correction."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Este dispositivo es un agregado de macOS.\n\nSi tus fuentes tienen relojes independientes (p. ej. dos interfaces USB distintas), configura la sincronización de reloj en Configuración de Audio MIDI — selecciona el dispositivo agregado y elige una fuente de reloj maestra en la pestaña correspondiente.\n\nEsta configuración hardware es más robusta que la corrección por software de Jack."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ce device est un agrégat macOS.\n\nSi vos sources ont des horloges indépendantes (ex. deux interfaces USB distinctes), pensez à configurer la synchronisation d'horloge dans Audio MIDI Setup — sélectionnez le device agrégé, puis choisissez une source d'horloge maître dans l'onglet dédié.\n\nCette configuration hardware est plus robuste que la correction logicielle de Jack."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Questo dispositivo è un aggregato macOS.\n\nSe le tue sorgenti hanno orologi indipendenti (es. due interfacce USB distinte), configura la sincronizzazione degli orologi in Configurazione Audio MIDI — seleziona il dispositivo aggregato, quindi scegli una sorgente di clock master nella scheda dedicata.\n\nQuesta configurazione hardware è più robusta della correzione software di Jack."
          }
        }
      }
    },
