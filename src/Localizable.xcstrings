    "alert.aggregate.button.open" : {
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ouvrir Audio MIDI Setup"
          }
        }
      }
    },
    "alert.aggregate.message" : {
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ce device est un agrégat macOS.\n\nSi vos sources ont des horloges indépendantes (ex. deux interfaces USB distinctes), pensez à configurer la synchronisation d'horloge dans Audio MIDI Setup — sélectionnez le device agrégé, puis choisissez une source d'horloge maître dans l'onglet dédié.\n\nCette configuration hardware est plus robuste que la correction logicielle de Jack."
          }
        }
      }
    },
    "alert.aggregate.suppress" : {
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ne plus afficher"
          }
        }
      }
    },
    "alert.aggregate.title" : {
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Device agrégé macOS"
          }
        }
      }
    },
    "alert.clock_drift.button.open" : {
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ouvrir Audio MIDI Setup"
          }
        }
      }
    },
    "alert.clock_drift.message" : {
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cette option active la correction de dérive d'horloge côté Jack.\n\nElle est utile si vos devices input et output ont des horloges de référence indépendantes (ex. micro USB + interface audio FireWire).\n\nUne alternative plus robuste : créer un device agrégé dans Audio MIDI Setup et y configurer la synchronisation d'horloge hardware. Le résultat est plus stable et transparent pour toutes les applications, pas seulement Jack."
          }
        }
      }
    },
    "alert.clock_drift.suppress" : {
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ne plus afficher"
          }
        }
      }
    },
    "alert.clock_drift.title" : {
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Clock drift correction"
          }
        }
      }
    },
    "alert.close.button.hide_window" : {
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fermer la fenêtre"
          }
        }
      }
    },
    "alert.close.button.quit" : {
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Quitter JackMate"
          }
        }
      }
    },
    "alert.close.button.quit_and_stop" : {
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Quitter et éteindre Jack"
          }
        }
      }
    },
    "alert.close.jack_running.message" : {
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Que souhaitez-vous faire ?\n\n• Fermer la fenêtre laisse Jack actif et JackMate accessible depuis la barre de menus.\n• Quitter JackMate ferme l'application mais laisse Jack tourner en arrière-plan.\n• Quitter et éteindre Jack arrête le serveur Jack et ferme JackMate."
          }
        }
      }
    },
    "alert.close.jack_running.title" : {
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le serveur Jack est actif"
          }
        }
      }
    },
    "alert.close.jack_stopped.message" : {
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fermer cette fenêtre ne quitte pas JackMate. L'icône dans la barre de menus vous permet de la rouvrir à tout moment."
          }
        }
      }
    },
    "alert.close.jack_stopped.title" : {
      "localizations" : {
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "JackMate reste actif dans la barre de menus"
          }
        }
      }
    },
