    "alert.close.jack_stopped.message": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Das Schließen dieses Fensters beendet JackMate nicht. Das Menüleistensymbol ermöglicht es dir, es jederzeit wieder zu öffnen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Closing this window does not quit JackMate. The menu bar icon lets you reopen it at any time."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cerrar esta ventana no sale de JackMate. El icono en la barra de menús te permite volver a abrirla en cualquier momento."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Fermer cette fenêtre ne quitte pas JackMate. L'icône dans la barre de menus vous permet de la rouvrir à tout moment."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Chiudere questa finestra non esce da JackMate. L'icona nella barra dei menu ti permette di riaprirla in qualsiasi momento."
          }
        }
      }
    },
