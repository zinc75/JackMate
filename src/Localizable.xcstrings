        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Jack server is running"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le serveur Jack est actif"
          }
        }
      }
    },
    "alert.close.jack_stopped.message": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Das Schließen dieses Fensters beendet JackMate nicht. Das Menüleistensymbol ermöglicht es dir, es jederzeit wieder zu öffnen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Closing this window does not quit JackMate. The menu bar icon lets you reopen it at any time."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Fermer cette fenêtre ne quitte pas JackMate. L'icône dans la barre de menus vous permet de la rouvrir à tout moment."
          }
        }
      }
    },
