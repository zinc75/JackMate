    "jack_not_installed.body": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Jack Audio Connection Kit ist ein kostenloses professionelles Open-Source-Audioserver-Programm, das für den Betrieb von JackMate erforderlich ist.\n\nDu kannst weiterhin Einstellungen durchsuchen und konfigurieren. Das Starten von Jack und das Laden von Studios ist deaktiviert, bis Jack installiert ist."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Jack Audio Connection Kit is a free, open-source professional audio server required for JackMate to function.\n\nYou can continue to browse and configure settings. Starting Jack and loading studios are disabled until Jack is installed."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Jack Audio Connection Kit est un serveur audio professionnel open source et gratuit, requis pour faire fonctionner JackMate.\n\nVous pouvez continuer à parcourir et configurer les paramètres. Le démarrage de Jack et le chargement des studios sont désactivés jusqu'à ce que Jack soit installé."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Jack Audio Connection Kit è un server audio professionale gratuito e open source necessario per il funzionamento di JackMate.\n\nPuoi continuare a sfogliare e configurare le impostazioni. L'avvio di Jack e il caricamento degli studi sono disabilitati fino a quando Jack non è installato."
          }
        }
      }
    },
